generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  description String
  website     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organizations")
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  results   Json?
  createdAt DateTime @default(now())

  @@map("search_logs")
}

model TempUser {                                                                                                                                                  
  id         String   @id @default(cuid())                
  name       String?                      
  email      String   @unique
  password   String                                                                                                                                               
  usageCount Int      @default(10)
  isActive   Boolean  @default(true)                                                                                                                              
  createdAt  DateTime @default(now())                     
  updatedAt  DateTime @updatedAt     
                                
  @@map("temp_users")                                                                                                                                             
}  
